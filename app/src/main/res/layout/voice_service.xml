<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/ime_surface"
    android:elevation="16dp">

    <!-- Transcription progress — thin strip at top edge -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/processing_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="false"
        android:progress="0"
        app:trackCornerRadius="0dp" />

    <!-- Mode / lang / keyboard / translate pill strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/ime_control_strip_bg"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp">

        <ImageButton
            android:id="@+id/btnModeAuto"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_auto_off_36dp"
            android:padding="10dp"
            android:contentDescription="@string/auto_button" />

        <ImageButton
            android:id="@+id/btnLang1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_counter_1_off_36dp"
            android:padding="10dp"
            android:contentDescription="@string/lang1" />

        <ImageButton
            android:id="@+id/btnLang2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_counter_2_off_36dp"
            android:padding="10dp"
            android:contentDescription="@string/lang2" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" />

        <ImageButton
            android:id="@+id/btnKeyboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_keyboard_36dp"
            android:padding="10dp"
            android:contentDescription="@string/exit_button" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" />

        <ImageButton
            android:id="@+id/btnTranslate"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_english_off_36dp"
            android:padding="10dp"
            android:contentDescription="@string/translate" />

    </LinearLayout>

    <!-- Error / status label — shown only when there is a message -->
    <TextView
        android:id="@+id/tv_status"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="#FFB3C6FF" />

    <!-- Record / Delete / Enter -->
    <RelativeLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="17dp"
        android:paddingBottom="22dp">

        <ImageButton
            android:id="@+id/btnRecord"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/rounded_button_background"
            android:src="@drawable/ic_mic_48dp"
            android:contentDescription="@string/record_button" />

        <ImageButton
            android:id="@+id/btnDel"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="@drawable/ime_ghost_button_bg"
            android:src="@drawable/ic_keyboard_del_48dp"
            android:padding="20dp"
            android:contentDescription="@string/delete_button" />

        <ImageButton
            android:id="@+id/btnEnter"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/ime_ghost_button_bg"
            android:src="@drawable/ic_keyboard_return_48dp"
            android:padding="20dp"
            android:contentDescription="@string/return_button" />

    </RelativeLayout>

</LinearLayout>
