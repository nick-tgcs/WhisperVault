<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/recognizer_background"
    android:layout_gravity="bottom"
    android:elevation="16dp">

    <!-- Progress bar pinned to the top edge -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/processing_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="false"
        android:progress="0"
        app:trackCornerRadius="0dp" />

    <!-- Cancel (left) and Auto-mode (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="10dp">

        <ImageButton
            android:id="@+id/btnCancel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/ime_ghost_button_bg"
            android:src="@drawable/ic_cancel_36dp"
            android:padding="9dp"
            android:contentDescription="@string/exit_button" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnModeAuto"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_auto_off_36dp"
            android:padding="4dp"
            android:contentDescription="@string/auto_button" />

        <ImageButton
            android:id="@+id/btnContinuous"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_continuous_off_36dp"
            android:padding="4dp"
            android:contentDescription="@string/continuous_button"
            android:visibility="visible" />

    </LinearLayout>

    <!-- Status text — fixed height prevents layout jumps -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="#FFB3C6FF"
        android:visibility="invisible" />

    <!-- Record button centred -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btnRecord"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/rounded_button_background"
            android:src="@drawable/ic_mic_48dp"
            android:contentDescription="@string/record_button" />

    </LinearLayout>

</LinearLayout>
